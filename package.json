{
  "name": "slotkit",
  "private": true,
  "workspaces": [
    "packages/*",
    "registry/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:push": "npm -w @slotkit/db run db:push",
    "db:migrate": "npm -w @slotkit/db run db:migrate",
    "db:seed": "npm -w @slotkit/db run db:seed",
    "db:generate": "npm -w @slotkit/db run db:generate"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.9.2"
}
