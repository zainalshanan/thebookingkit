{
  "name": "@thebookingkit/db",
  "version": "0.1.5",
  "description": "Drizzle ORM schema, migrations, and TypeScript types for The Booking Kit's 22 Postgres tables",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thebookingkit/thebookingkit.git",
    "directory": "packages/db"
  },
  "homepage": "https://thebookingkit.com",
  "keywords": [
    "thebookingkit",
    "booking",
    "scheduling",
    "drizzle",
    "postgres",
    "schema"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schema": {
      "import": "./dist/schema/index.js",
      "types": "./dist/schema/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.0",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
