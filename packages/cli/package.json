{
  "name": "@thebookingkit/cli",
  "version": "0.2.1",
  "description": "The Booking Kit CLI — scaffold projects, add 30+ booking UI components, and manage migrations",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thebookingkit/thebookingkit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://thebookingkit.com",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "thebookingkit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "keywords": [
    "thebookingkit",
    "booking",
    "scheduling",
    "cli"
  ]
}
