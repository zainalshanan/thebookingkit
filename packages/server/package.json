{
  "name": "@thebookingkit/server",
  "version": "0.2.0",
  "description": "Backend APIs, auth middleware, webhooks, notifications, and multi-tenant utilities for The Booking Kit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thebookingkit/thebookingkit.git",
    "directory": "packages/server"
  },
  "homepage": "https://thebookingkit.com",
  "keywords": [
    "thebookingkit",
    "booking",
    "scheduling",
    "server",
    "api"
  ],
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@thebookingkit/core": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
