{
  "name": "@thebookingkit/core",
  "version": "0.2.0",
  "description": "Headless scheduling engine: slot computation, RRULE expansion, team assignment, resource & capacity booking, recurring bookings, walk-ins, and kiosk mode",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thebookingkit/thebookingkit.git",
    "directory": "packages/core"
  },
  "homepage": "https://thebookingkit.com",
  "keywords": [
    "thebookingkit",
    "booking",
    "scheduling",
    "availability",
    "slots",
    "rrule",
    "timezone"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "rrule": "^2.8.0"
  },
  "devDependencies": {
    "@thebookingkit/db": "*",
    "@types/node": "^25.3.5",
    "fast-check": "^4.5.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
